---
import "../styles/global.css";
import { ViewTransitions } from 'astro:transitions';

export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'SPHERE — Human & Digital Rights',
  description = 'SPHERE: Human rights, digital rights, and community action in Sri Lanka.',
} = Astro.props as Props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body>
    <header class="header">
      <div class="container header__wrap">
        <a class="brand" href="/" aria-label="SPHERE">
          <img class="brand__mark" src="/logo.png" alt="" aria-hidden="true" />
          <div>
            <span class="brand__name">SPHERE</span>
            <span class="brand__tag">Sphere Research and Advocacy</span>
          </div>
        </a>
        <div class="header__wrap-right">
          <nav class="nav" id="primary-nav" aria-label="Primary">
            <a class="nav__link" href="/home">Home</a>
            <a class="nav__link" href="/cdpr">CDPR</a>
            <a class="nav__link" href="/about">About Us</a>
            <a class="nav__link" href="/blog">Blog</a>
            <a class="nav__link" href="/contact">Contact</a>
          </nav>
          <button
            class="menu"
            id="nav-toggle"
            type="button"
            aria-label="Toggle menu"
            aria-expanded="false"
            aria-controls="primary-nav"
          >
            &equiv;
          </button>
        </div>
      </div>
    </header>
    <slot />
    <footer class="footer">
      <div class="container footer__grid">
        <div class="footer__brandtext">
          <strong>SPHERE</strong> — Society for the Progress, Human Rights,
          Empowerment & Equity<br />
          <span>
            © <span id="year"></span> SPHERE Research and Advocacy. All rights reserved.
          </span>
        </div>
        <div class="footer__meta">
          <span class="block">Focus: Sri Lanka</span>
          <span class="block">
            <a href="mailto:hello@sphereresearch.org">hello@sphereresearch.org</a>
          </span>
        </div>
      </div>
    </footer>
    <script is:inline>
      // Initialize menu on page load and after view transitions
      function initMenu() {
        document.getElementById("year").textContent = new Date().getFullYear();
        
        const navToggle = document.getElementById("nav-toggle");
        const primaryNav = document.getElementById("primary-nav");
        
        if (navToggle && primaryNav) {
          // Remove any existing listeners by cloning the button
          const newNavToggle = navToggle.cloneNode(true);
          navToggle.parentNode.replaceChild(newNavToggle, navToggle);
          
          // Add click listener to toggle menu
          newNavToggle.addEventListener("click", (e) => {
            e.stopPropagation();
            const isOpen = primaryNav.classList.toggle("is-open");
            newNavToggle.setAttribute("aria-expanded", String(isOpen));
          });
          
          // Close menu when clicking outside
          document.addEventListener("click", (event) => {
            if (
              !primaryNav.contains(event.target) &&
              !newNavToggle.contains(event.target)
            ) {
              primaryNav.classList.remove("is-open");
              newNavToggle.setAttribute("aria-expanded", "false");
            }
          });
          
          // Close menu when clicking a nav link
          const navLinks = primaryNav.querySelectorAll('.nav__link');
          navLinks.forEach(link => {
            link.addEventListener('click', () => {
              primaryNav.classList.remove("is-open");
              newNavToggle.setAttribute("aria-expanded", "false");
            });
          });
        }
      }
      
      // Run on initial page load
      initMenu();
      
      // Re-run after each page transition
      document.addEventListener('astro:after-swap', initMenu);
    </script>
  </body>
</html>
