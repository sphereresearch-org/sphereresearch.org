---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="SPHERE — Society for the Progress, Human Rights, Empowerment & Equity"
  description="SPHERE: Bridging human rights advocacy and community action in Sri Lanka. Centre for Digital Policy Research (CDPR), digital rights, trainings, and civic empowerment."
>
  <main class="page page--home">
    <!-- Hero -->
    <section id="home" class="section section--hero">
      <div class="container">
        <div class="hero">
          <div>
            <div class="hero__eyebrow">Born of the 2022 People’s Struggle</div>
            <h1 class="hero__title">
              Bridging human rights advocacy and community action in Sri Lanka.
            </h1>
            <p class="hero__desc">
              SPHERE (Society for the Progress, Human Rights, Empowerment &
              Equity) sustains the momentum of civic participation—defending
              civil and political rights, advancing digital rights, and
              empowering communities to shape a just, democratic future.
            </p>
            <div class="hero__badges" aria-label="Key facts" style="padding: 8px 0px;">
              <span class="badge">National focus</span>
              <span class="badge">Incorporation pending (Section 32)</span>
              <span class="badge badge--amber">Advocacy • Research • Training</span>
            </div>
            <div class="hero__actions">
              <a class="btn" href="#priorities">See 2025–2026 Priorities</a>
              <a class="btn btn--ghost" href="#impact">Our Impact</a>
            </div>
          </div>
          <div>
            <div class="hero__panel" role="note" aria-label="Recent actions">
              <strong>Recent actions</strong>
              <ul class="hero__list">
                <li>
                  <span>•</span>
                  <span>
                    HRCSL complaint regarding the blocking of activist media on
                    Facebook by police.
                  </span>
                </li>
                <li>
                  <span>•</span>
                  <span>
                    Case monitoring: detention of
                    <em>Rifai Mohamed Suhail</em> under the PTA.
                  </span>
                </li>
                <li>
                  <span>•</span>
                  <span>
                    RTI request on staffing at the Presidential Media Division
                    (PMD).
                  </span>
                </li>
              </ul>
              <div class="btn-row">
                <a class="btn btn--ghost" href="#mission">About SPHERE</a>
                <a class="btn btn--ghost" href="#cdpr">About CDPR</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Mission -->
    <section id="mission" class="section">
      <div class="container grid-2">
        <div>
          <h2 class="section__title">Why SPHERE?</h2>
          <p class="section__kicker">From protest to durable participation.</p>
          <p style="line-height: 1.5;">
            SPHERE was created to prevent a slide back into civic passivity
            after the 2022 people’s struggle. We connect human rights advocacy
            with community‑level action—standing up for freedom of expression,
            association, and privacy while strengthening everyday democratic
            practice.
          </p>
          <p style="line-height: 1.6; font-size: small;">
            <strong>Legal status:</strong> Incorporation in progress as a
            company limited by guarantee (Section 32). Name reservation approved
            for <em>SPHERE Research and Advocacy</em>.
          </p>
        </div>
        <div class="cards cards--three">
          <article class="card">
            <h3 class="card__title">Advocacy</h3>
            <p class="card__desc">
              Strategic interventions with regulators and institutions; public
              interest complaints; evidence‑led campaigns.
            </p>
          </article>
          <article class="card">
            <h3 class="card__title">Research</h3>
            <p class="card__desc">
              Legal and policy analysis on digital rights through the Centre for
              Digital Policy Research (CDPR).
            </p>
          </article>
          <article class="card">
            <h3 class="card__title">Training</h3>
            <p class="card__desc">
              Capacity‑building through <em>Our Rights – Our Future</em> and
              similar programs to empower communities and defenders.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- Impact -->
    <section id="impact" class="section">
      <div class="container">
        <h2 class="section__title">Early Impact</h2>
        <p class="section__kicker">
          Watchdog and advocate—already making dents.
        </p>
        <div class="grid-3">
          <article class="card">
            <h3 class="card__title">HRCSL Complaint</h3>
            <p class="card__desc">
              Challenging police‑linked blocking of activist content on
              Facebook.
            </p>
          </article>
          <article class="card">
            <h3 class="card__title">PTA Monitoring</h3>
            <p class="card__desc">
              Tracking detention of Rifai Mohamed Suhail under the PTA.
            </p>
          </article>
          <article class="card">
            <h3 class="card__title">RTI to PMD</h3>
            <p class="card__desc">
              Transparency action on staffing at the Presidential Media
              Division.
            </p>
          </article>
        </div>
        <p class="impact__note">
          Supported by partners and allies; international support to date
          includes AJWS.
        </p>
      </div>
    </section>

    <!-- Priorities -->
    <section id="priorities" class="section">
      <div class="container grid-2">
        <div>
          <h2 class="section__title">2025–2026 Priorities</h2>
          <p class="section__kicker">Clear, achievable, impact‑driven.</p>
          <ul class="list">
            <li>Complete legal registration and strengthen governance.</li>
            <li>
              Deliver
              <strong>Civil & Political Rights in the Digital Age</strong> and
              scale <strong>Our Rights – Our Future</strong> trainings.
            </li>
            <li>
              Establish <strong>CDPR</strong> as Sri Lanka’s leading voice on
              digital rights in law and policy.
            </li>
            <li>
              Run a national
              <strong>digital rights advocacy campaign</strong> via CDPR.
            </li>
          </ul>
        </div>
        <div class="cards cards--three">
          <article class="card">
            <h3 class="card__title">Institutional Strength</h3>
            <p class="card__desc">
              Finalize incorporation; build transparent systems; publish
              policies.
            </p>
          </article>
          <article class="card">
            <h3 class="card__title">Public Education</h3>
            <p class="card__desc">
              Expand rights literacy and safety practices for communities and
              defenders.
            </p>
          </article>
          <article class="card">
            <h3 class="card__title">Policy Impact</h3>
            <p class="card__desc">
              Evidence‑based advocacy shaping digital rights frameworks.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- CDPR Focus -->
    <section id="cdpr" class="section">
      <div class="container grid-2">
        <div>
          <h2 class="section__title">
            Centre for Digital Policy Research (CDPR)
          </h2>
          <p class="section__kicker">
            Legal and policy engine for digital rights.
          </p>
          <p style="line-height: 1.5;">
            CDPR leads SPHERE’s legal‑policy agenda—producing research,
            convening stakeholders, and driving advocacy on privacy, expression,
            surveillance, platform accountability, and civic technology. CDPR
            will front the national digital rights campaign and provide rapid
            policy response capacity.
          </p>
        </div>
        <div class="cards cards--three">
          <article class="card">
            <h3 class="card__title">Focus Areas</h3>
            <p class="card__desc">
              Data protection, platform regulation, speech & assembly online,
              due process, transparency.
            </p>
          </article>
          <article class="card">
            <h3 class="card__title">Outputs</h3>
            <p class="card__desc">
              Briefs, explainer notes, stakeholder roundtables, model clauses,
              media commentary.
            </p>
          </article>
          <article class="card">
            <h3 class="card__title">Community Link</h3>
            <p class="card__desc">
              Bridging legal work with trainings and community needs.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- Team -->
    <section id="team" class="section">
      <div class="container grid-2">
        <div>
          <h2 class="section__title">Team & Structure</h2>
          <p class="section__kicker">Lean core, networked expertise.</p>
          <ul class="list">
            <li><strong>Board of Directors</strong> — Strategic oversight with an independent majority.</li>
            <li><strong>Core Team</strong> — Lean staff across advocacy, research, training, and operations.</li>
            <li><strong>Leadership</strong> — Cross‑functional co‑founders guiding programs and partnerships.</li>
            <li><strong>Advisory Board</strong> — Subject‑matter experts and legal/technical consultants engaged as needed.</li>
            <li><strong>Grassroots Network</strong> — Community partners, local organizers, and field trainers across Sri Lanka.</li>
          </ul>
        </div>
        <div class="cards cards--three">
          <article class="card">
            <h3 class="card__title">How we work</h3>
            <p class="card__desc">
              Evidence‑first, non‑partisan, collaborative with civil society,
              media, and legal experts.
            </p>
          </article>
          <article class="card">
            <h3 class="card__title">Values</h3>
            <p class="card__desc">
              Rights‑centered, community‑rooted, transparent, secure by design.
            </p>
          </article>
          <article class="card">
            <h3 class="card__title">Opportunities</h3>
            <p class="card__desc">
              Partners, volunteers, and pro‑bono advisors are welcome.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- Contact / CTA -->
    <section id="contact" class="section">
      <div class="container grid-2">
        <div>
          <h2 class="section__title">Stay in touch</h2>
          <p class="section__kicker">
            Stay informed about our advocacy, research, and trainings.
          </p>
          <p style="line-height: 1.5">
            Email us at
            <a class="link" href="mailto:hello@sphereresearch.org">
              hello@sphereresearch.org
            </a>
            or follow updates via our upcoming channels. For partnership
            inquiries, please include your organization name and area of
            interest.
          </p>
          <div class="btn-row mt-8">
            <a
              class="btn"
              href="mailto:hello@sphereresearch.org?subject=Partnership%20Inquiry%20—%20SPHERE"
              >Partnerships</a
            >
            <a class="btn btn--ghost" href="#home">Back to top</a>
          </div>
        </div>
        <form
          class="card"
          onsubmit="event.preventDefault(); alert('Thanks! We\'ll keep you posted.');"
        >
          <h3 class="card__title">Get updates</h3>
          <p class="card__desc">
            Leave your email. We’ll reach out when the full site and campaigns
            go live.
          </p>
          <div style="display: grid; gap: 10px; margin-top: 8px">
            <label for="email" class="form__label">Email address</label>
            <input
              id="email"
              type="email"
              required
              placeholder="you@example.org"
              class="input"
            />
            <button class="btn" type="submit">Subscribe</button>
            <small class="text--muted">
              We respect privacy. No spam; easy opt‑out.
            </small>
          </div>
        </form>
      </div>
    </section>
  </main>
</BaseLayout>
