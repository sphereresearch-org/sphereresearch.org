---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from 'astro:content';
import BlogCard from '../../components/BlogCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props as { post: any };
const { Content } = await post.render();

// Format date
const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// Get related posts (same category, excluding current)
const allPosts = await getCollection('blog', ({ data }) => data.draft !== true);
const relatedPosts = allPosts
  .filter(p => p.slug !== post.slug && p.data.category === post.data.category)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

// Category color
const categoryColors: Record<string, string> = {
  cdpr: 'rgba(2, 132, 199, 0.1)',
  advocacy: 'rgba(16, 185, 129, 0.1)',
  research: 'rgba(139, 92, 246, 0.1)',
  training: 'rgba(245, 158, 11, 0.1)',
  general: 'rgba(107, 114, 128, 0.1)',
};
---

<BaseLayout title={`${post.data.title} — SPHERE Blog`} description={post.data.description}>
  <main class="page page-animate">
    <!-- Article Header -->
    <article class="blog-post">
      <header class="blog-post__header">
        <div class="container" style="max-width: 800px;">
          <a href="/blog" class="blog-post__back">← Back to Blog</a>
          
          <div class="blog-post__category-badge" style={`background: ${categoryColors[post.data.category]}`}>
            {post.data.category.toUpperCase()}
          </div>
          
          <h1 class="blog-post__title">{post.data.title}</h1>
          
          <p class="blog-post__description">{post.data.description}</p>
          
          <div class="blog-post__meta">
            <div class="blog-post__author">
              {post.data.authorImage && (
                <img 
                  src={post.data.authorImage} 
                  alt={post.data.author}
                  class="blog-post__author-image"
                />
              )}
              <div>
                <div class="blog-post__author-name">{post.data.author}</div>
                {post.data.authorRole && (
                  <div class="blog-post__author-role">{post.data.authorRole}</div>
                )}
              </div>
            </div>
            <time class="blog-post__date" datetime={post.data.date.toISOString()}>
              {formattedDate}
            </time>
          </div>
          
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="blog-post__tags">
              {post.data.tags.map((tag: string) => (
                <span class="blog-post__tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </header>

      <!-- Cover Image -->
      {post.data.coverImage && (
        <div class="blog-post__cover-wrapper">
          <img 
            src={post.data.coverImage} 
            alt={post.data.title}
            class="blog-post__cover"
          />
        </div>
      )}

      <!-- Article Content -->
      <div class="blog-post__content">
        <div class="container" style="max-width: 800px;">
          <div class="prose">
            <Content />
          </div>
        </div>
      </div>

      <!-- Footer -->
      <footer class="blog-post__footer">
        <div class="container" style="max-width: 800px;">
          <div class="blog-post__share">
            <span style="font-weight: 600; color: var(--text);">Share this post:</span>
            <div style="display: flex; gap: 12px;">
              <a 
                href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(`https://sphereresearch.org/blog/${post.slug}`)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn--ghost"
                style="padding: 8px 16px;"
              >
                Twitter
              </a>
              <a 
                href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(`https://sphereresearch.org/blog/${post.slug}`)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn--ghost"
                style="padding: 8px 16px;"
              >
                Facebook
              </a>
              <a 
                href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(`https://sphereresearch.org/blog/${post.slug}`)}&title=${encodeURIComponent(post.data.title)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn--ghost"
                style="padding: 8px 16px;"
              >
                LinkedIn
              </a>
            </div>
          </div>
        </div>
      </footer>
    </article>

    <!-- Related Posts -->
    {relatedPosts.length > 0 && (
      <section class="section" style="background: linear-gradient(180deg, rgba(255,255,255,0.5), transparent);">
        <div class="container">
          <h2 class="section__title" style="text-align: center; margin-bottom: 32px;">
            Related Posts
          </h2>
          <div class="blog-grid">
            {relatedPosts.map((relatedPost) => (
              <BlogCard post={relatedPost} showCategory={false} compact={true} />
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
</BaseLayout>

<style>
  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 768px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .blog-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .blog-post {
    padding-bottom: 60px;
  }

  .blog-post__header {
    padding: 80px 0 40px;
    background: linear-gradient(180deg, rgba(255,255,255,0), rgba(255,255,255,0.6));
  }

  .blog-post__back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--link);
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 24px;
    transition: transform 0.2s ease;
  }

  .blog-post__back:hover {
    transform: translateX(-4px);
  }

  .blog-post__category-badge {
    display: inline-block;
    padding: 6px 14px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--text);
    margin-bottom: 16px;
  }

  .blog-post__title {
    font-size: clamp(28px, 5vw, 42px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
  }

  .blog-post__description {
    font-size: 18px;
    line-height: 1.5;
    color: #475569;
    margin: 0 0 28px;
  }

  .blog-post__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 0;
    border-top: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
    flex-wrap: wrap;
  }

  .blog-post__author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .blog-post__author-image {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--border);
  }

  .blog-post__author-name {
    font-size: 15px;
    font-weight: 700;
    color: var(--text);
  }

  .blog-post__author-role {
    font-size: 13px;
    color: var(--muted);
  }

  .blog-post__date {
    font-size: 14px;
    color: var(--muted);
  }

  .blog-post__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }

  .blog-post__tag {
    display: inline-block;
    padding: 6px 12px;
    border-radius: 999px;
    background: rgba(2, 6, 23, 0.05);
    color: #475569;
    font-size: 12px;
    font-weight: 600;
  }

  .blog-post__cover-wrapper {
    margin: 40px 0 60px;
  }

  .blog-post__cover {
    width: 100%;
    max-height: 500px;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl);
  }

  .blog-post__content {
    padding: 0 0 60px;
  }

  .prose {
    color: #334155;
    font-size: 17px;
    line-height: 1.75;
  }

  .prose > * + * {
    margin-top: 24px;
  }

  .prose h2 {
    font-size: 28px;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--text);
    margin-top: 48px;
    margin-bottom: 20px;
  }

  .prose h3 {
    font-size: 22px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--text);
    margin-top: 36px;
    margin-bottom: 16px;
  }

  .prose h4 {
    font-size: 18px;
    line-height: 1.4;
    color: var(--text);
    margin-top: 28px;
    margin-bottom: 12px;
  }

  .prose p {
    margin: 20px 0;
  }

  .prose strong {
    color: var(--text);
    font-weight: 600;
  }

  .prose a {
    color: var(--link);
    text-decoration: underline;
    text-decoration-color: rgba(3, 105, 161, 0.3);
    text-underline-offset: 2px;
    transition: text-decoration-color 0.2s ease;
  }

  .prose a:hover {
    text-decoration-color: rgba(3, 105, 161, 1);
  }

  .prose ul,
  .prose ol {
    padding-left: 28px;
    margin: 20px 0;
  }

  .prose li {
    margin: 8px 0;
  }

  .prose li > ul,
  .prose li > ol {
    margin: 8px 0;
  }

  .prose blockquote {
    margin: 32px 0;
    padding: 20px 24px;
    border-left: 4px solid var(--accent);
    background: rgba(2, 132, 199, 0.05);
    border-radius: var(--radius-sm);
    font-style: italic;
  }

  .prose img {
    max-width: 100%;
    border-radius: var(--radius);
    margin: 32px 0;
    box-shadow: var(--shadow);
  }

  .prose hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 48px 0;
  }

  .blog-post__footer {
    padding: 40px 0;
    border-top: 1px solid var(--border);
  }

  .blog-post__share {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
</style>
