---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props as { post: any };
const { Content } = await post.render();
---
<BaseLayout title={post.data.title} description={post.data.description}>
  <section class="section">
    <div class="container">
      <h1 class="hero__title" style="font-size:28px;">{post.data.title}</h1>
      <div class="post__meta mt-8">
        <span class="text--muted">{new Date(post.data.pubDate).toLocaleDateString()}</span>
        {post.data.author ? (
          <span class="text--muted">By {post.data.author}</span>
        ) : null}
        {post.data.updatedDate ? (
          <span class="text--muted">Updated {new Date(post.data.updatedDate).toLocaleDateString()}</span>
        ) : null}
      </div>
      {post.data.tags?.length ? (
        <div class="tags mt-8">
          {post.data.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      ) : null}
      {post.data.coverUrl ? (
        <img class="post__cover mt-8" src={post.data.coverUrl} alt={post.data.title} loading="lazy" />
      ) : null}
      <article class="card mt-8">
        <div class="prose">
          <Content />
        </div>
      </article>
      <p class="mt-8"><a class="link" href="/blog">← Back to blog</a></p>
    </div>
  </section>
</BaseLayout>
