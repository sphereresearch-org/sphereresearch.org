<script is:inline>
  let selectedContentType = 'articles';
  let selectedAuthor = null;

  // Set today's date as default
  document.addEventListener('DOMContentLoaded', function() {
    const today = new Date().toISOString().split('T')[0];
    document.getElementById('date').value = today;
  });

  function showCreatePanel() {
    document.getElementById('createPanel').style.display = 'block';
    document.getElementById('createBtn').style.display = 'none';
    document.getElementById('createPanel').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function hideCreatePanel() {
    document.getElementById('createPanel').style.display = 'none';
    document.getElementById('createBtn').style.display = '';
  }

  function setContentType(type, btn) {
    selectedContentType = type;
    document.querySelectorAll('.toggle-btn').forEach(b => b.classList.remove('toggle-btn--active'));
    btn.classList.add('toggle-btn--active');
  }

  function selectAuthor(el) {
    document.querySelectorAll('.author-option').forEach(o => o.classList.remove('author-option--selected'));
    el.classList.add('author-option--selected');
    selectedAuthor = {
      name: el.dataset.name,
      role: el.dataset.role,
      image: el.dataset.image,
    };
    // Clear custom author fields
    document.getElementById('customAuthorName').value = '';
    document.getElementById('customAuthorRole').value = '';
    document.getElementById('customAuthorImage').value = '';
  }

  function getAuthorInfo() {
    const customName = document.getElementById('customAuthorName').value.trim();
    if (customName) {
      return {
        name: customName,
        role: document.getElementById('customAuthorRole').value.trim(),
        image: document.getElementById('customAuthorImage').value.trim(),
      };
    }
    return selectedAuthor;
  }

  function insertMarkdown(before, after) {
    const textarea = document.getElementById('content');
    const start = textarea.selectionStart;
    const end = textarea.selectionEnd;
    const text = textarea.value;
    const selectedText = text.substring(start, end) || 'text';
    textarea.value = text.substring(0, start) + before + selectedText + after + text.substring(end);
    textarea.focus();
    textarea.selectionStart = start + before.length;
    textarea.selectionEnd = start + before.length + selectedText.length;
  }

  function generateSlug(title) {
    return title.toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '')
      .substring(0, 60);
  }

  function generateFrontmatter() {
    const title = document.getElementById('title').value.trim();
    const description = document.getElementById('description').value.trim();
    const category = document.getElementById('category').value;
    const date = document.getElementById('date').value;
    const coverImage = document.getElementById('coverImage').value.trim();
    const tagsRaw = document.getElementById('tags').value.trim();
    const isDraft = document.getElementById('isDraft').checked;
    const content = document.getElementById('content').value;
    const author = getAuthorInfo();

    if (!title || !description || !author || !date || !coverImage || !content) {
      alert('Please fill in all required fields and select an author.');
      return null;
    }

    const tags = tagsRaw ? tagsRaw.split(',').map(t => `"${t.trim()}"`).join(', ') : '';

    let frontmatter = `---
title: "${title.replace(/"/g, '\\"')}"
description: "${description.replace(/"/g, '\\"')}"
author: "${author.name}"`;

    if (author.role) frontmatter += `\nauthorRole: "${author.role}"`;
    if (author.image) frontmatter += `\nauthorImage: "${author.image}"`;

    frontmatter += `
date: ${date}
category: "${category}"
tags: [${tags}]
coverImage: "${coverImage}"
draft: ${isDraft}
---

${content}`;

    return { frontmatter, title };
  }

  function generateFile() {
    const result = generateFrontmatter();
    if (!result) return;

    const { frontmatter, title } = result;
    const slug = generateSlug(title);
    const filename = `${slug}.md`;

    const blob = new Blob([frontmatter], { type: 'text/markdown' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);

    // Show success toast
    showToast(`✅ File "${filename}" downloaded! Place it in src/content/${selectedContentType}/`);
  }

  function previewArticle() {
    const title = document.getElementById('title').value.trim() || 'Untitled Article';
    const description = document.getElementById('description').value.trim();
    const content = document.getElementById('content').value.trim();
    const author = getAuthorInfo();
    const coverImage = document.getElementById('coverImage').value.trim();
    const category = document.getElementById('category').value;
    const date = document.getElementById('date').value;

    let html = `<h1>${escapeHtml(title)}</h1>`;
    html += `<div class="preview-meta">`;
    if (author && author.image) {
      html += `<img src="${escapeHtml(author.image)}" alt="${escapeHtml(author.name)}" />`;
    }
    html += `<div>`;
    if (author) html += `<strong>${escapeHtml(author.name)}</strong>`;
    if (author && author.role) html += ` · ${escapeHtml(author.role)}`;
    html += `</div>`;
    if (date) html += `<div style="margin-left: auto;">${new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</div>`;
    html += `</div>`;
    if (description) html += `<p style="color: #64748b; font-style: italic; margin-bottom: 20px;">${escapeHtml(description)}</p>`;
    if (coverImage) html += `<img src="${escapeHtml(coverImage)}" alt="Cover" style="width: 100%; max-height: 300px; object-fit: cover; border-radius: 12px; margin-bottom: 24px;" onerror="this.style.display='none'" />`;
    html += `<div style="margin-top: 20px;"><strong>Category:</strong> <span class="category-badge category-badge--${category}" style="vertical-align: middle;">${category.toUpperCase()}</span></div>`;
    html += `<hr style="margin: 20px 0; border: none; border-top: 1px solid #e2e8f0;">`;
    html += `<pre style="white-space: pre-wrap; font-size: 0.88rem; line-height: 1.7;">${escapeHtml(content || 'No content yet...')}</pre>`;

    document.getElementById('previewBody').innerHTML = html;
    document.getElementById('previewOverlay').style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function hidePreview() {
    document.getElementById('previewOverlay').style.display = 'none';
    document.body.style.overflow = '';
  }

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function switchSection(section, btn) {
    document.querySelectorAll('.section-tab').forEach(t => t.classList.remove('section-tab--active'));
    btn.classList.add('section-tab--active');
    document.querySelectorAll('.content-section').forEach(s => {
      s.style.display = s.dataset.section === section ? 'block' : 'none';
    });
  }

  function showToast(message) {
    const toast = document.createElement('div');
    toast.textContent = message;
    toast.style.cssText = `
      position: fixed;
      bottom: 32px;
      right: 32px;
      background: #0f172a;
      color: white;
      padding: 16px 24px;
      border-radius: 12px;
      font-size: 0.9rem;
      font-weight: 600;
      box-shadow: 0 10px 30px rgba(0,0,0,0.2);
      z-index: 99999;
      animation: slideUp 0.3s ease;
      max-width: 400px;
    `;
    document.body.appendChild(toast);
    setTimeout(() => {
      toast.style.opacity = '0';
      toast.style.transition = 'opacity 0.3s ease';
      setTimeout(() => toast.remove(), 300);
    }, 5000);
  }

  // Close preview on Escape
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') hidePreview();
  });
</script>

<style>
