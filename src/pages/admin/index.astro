---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from 'astro:content';

// Get all articles
const allArticles = (await getCollection('articles'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const publishedArticles = allArticles.filter(p => !p.data.draft);
const draftArticles = allArticles.filter(p => p.data.draft);

// Get all blog posts
const allBlog = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const publishedBlog = allBlog.filter(p => !p.data.draft);
const draftBlog = allBlog.filter(p => p.data.draft);

// Team members for author selection
const teamMembers = [
  { name: "Praveen D Fernando", role: "Director of Digital Policy", image: "/team/praveen.jpg" },
  { name: "Anuruddha Bandara", role: "Digital Rights Advocate", image: "/team/anuruddha_bandara.png" },
  { name: "Kasun Indika", role: "Software Engineer & Digital Rights", image: "/team/kasun_indika.png" },
  { name: "Tharushi Dishara", role: "Attorney At Law", image: "/team/tharushi_dishara.png" },
  { name: "Nathali Rangajeewa", role: "Social Activist", image: "/team/nathali_rangajeewa.png" },
  { name: "Angela Nanayakkara", role: "Human Rights Volunteer", image: "/team/angela_nanayakkara.png" },
  { name: "Sathya Charith", role: "Marketing & Communications", image: "/team/sathya_charith.png" },
  { name: "Lahiru Lakmina Fernando", role: "Technology & Digital Platforms", image: "/team/lahiru_lakmina.png" },
  { name: "Sherene Dias", role: "Finance & Audit", image: "/team/placeholder_1.png" },
  { name: "Pubudu Viduranga", role: "Community Mobilization", image: "/team/placeholder_2.png" },
];
---

<BaseLayout title="Admin Dashboard — SPHERE" description="Manage articles and blog posts">
  <main class="page">

    <!-- Login Gate -->
    <div class="login-gate" id="loginGate">
      <div class="login-card">
        <div class="login-card__logo">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: #0284c7;"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h2 class="login-card__title">Admin Access</h2>
        <p class="login-card__desc">Enter your password to access the dashboard</p>
        <form onsubmit="return handleLogin(event)">
          <div class="login-card__field">
            <input type="password" id="loginPassword" class="login-card__input" placeholder="Enter password" autocomplete="current-password" autofocus />
          </div>
          <p class="login-card__error" id="loginError" style="display: none;">Incorrect password. Please try again.</p>
          <button type="submit" class="btn btn--primary btn--lg login-card__btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: -3px; margin-right: 6px;"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            Sign In
          </button>
        </form>
        <p class="login-card__footer">SPHERE Admin Panel</p>
      </div>
    </div>

    <section class="section" style="padding-top: 40px; display: none;" id="adminContent">
      <div class="container" style="max-width: 1200px;">

        <!-- Header -->
        <div class="admin-header">
          <div>
            <h1 class="admin-header__title">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: -5px; margin-right: 8px; color: #0284c7;"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
              Admin Dashboard
            </h1>
            <p class="admin-header__sub">Manage articles, blog posts, and content</p>
          </div>
          <button class="btn btn--primary btn--lg" onclick="showCreatePanel()" id="createBtn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: -3px; margin-right: 6px;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Create New
          </button>
        </div>

        <!-- Stats Cards -->
        <div class="admin-stats">
          <div class="stat-card stat-card--blue">
            <div class="stat-card__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
            </div>
            <div class="stat-card__value">{allArticles.length}</div>
            <div class="stat-card__label">Articles</div>
          </div>
          <div class="stat-card stat-card--emerald">
            <div class="stat-card__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            </div>
            <div class="stat-card__value">{allBlog.length}</div>
            <div class="stat-card__label">Blog Posts</div>
          </div>
          <div class="stat-card stat-card--green">
            <div class="stat-card__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <div class="stat-card__value">{publishedArticles.length + publishedBlog.length}</div>
            <div class="stat-card__label">Published</div>
          </div>
          <div class="stat-card stat-card--amber">
            <div class="stat-card__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            </div>
            <div class="stat-card__value">{draftArticles.length + draftBlog.length}</div>
            <div class="stat-card__label">Drafts</div>
          </div>
        </div>

        <!-- Create Panel (hidden by default) -->
        <div class="create-panel" id="createPanel" style="display: none;">
          <div class="create-panel__header">
            <h2 class="create-panel__title">Create New Content</h2>
            <button class="create-panel__close" onclick="hideCreatePanel()">×</button>
          </div>

          <form id="createForm" onsubmit="return false;">
            <!-- Content Type -->
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Content Type</label>
                <div class="toggle-group">
                  <button type="button" class="toggle-btn toggle-btn--active" data-type="articles" onclick="setContentType('articles', this)">Article</button>
                  <button type="button" class="toggle-btn" data-type="blog" onclick="setContentType('blog', this)">Blog Post</button>
                </div>
              </div>
            </div>

            <!-- Title -->
            <div class="form-group">
              <label class="form-label" for="title">Title *</label>
              <input type="text" id="title" class="form-input" placeholder="Enter article title..." required />
            </div>

            <!-- Description -->
            <div class="form-group">
              <label class="form-label" for="description">Description *</label>
              <textarea id="description" class="form-input form-textarea" rows="3" placeholder="Brief summary of the article..." required></textarea>
            </div>

            <!-- Author Selection -->
            <div class="form-group">
              <label class="form-label">Author *</label>
              <div class="author-grid" id="authorGrid">
                {teamMembers.map((member, i) => (
                  <div class="author-option" data-name={member.name} data-role={member.role} data-image={member.image} onclick="selectAuthor(this)">
                    <img src={member.image} alt={member.name} class="author-option__avatar" />
                    <div class="author-option__info">
                      <div class="author-option__name">{member.name}</div>
                      <div class="author-option__role">{member.role}</div>
                    </div>
                    <div class="author-option__check">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Custom Author (if not in the list) -->
            <details class="custom-author-toggle">
              <summary class="custom-author-summary">Or enter custom author details</summary>
              <div class="form-row" style="margin-top: 16px;">
                <div class="form-group">
                  <label class="form-label" for="customAuthorName">Author Name</label>
                  <input type="text" id="customAuthorName" class="form-input" placeholder="Full name" />
                </div>
                <div class="form-group">
                  <label class="form-label" for="customAuthorRole">Designation</label>
                  <input type="text" id="customAuthorRole" class="form-input" placeholder="e.g. Research Analyst" />
                </div>
              </div>
              <div class="form-group">
                <label class="form-label" for="customAuthorImage">Author Photo URL</label>
                <input type="text" id="customAuthorImage" class="form-input" placeholder="/team/photo.jpg" />
              </div>
            </details>

            <!-- Category & Date -->
            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="category">Category *</label>
                <select id="category" class="form-input form-select">
                  <option value="cdpr">CDPR</option>
                  <option value="advocacy">Advocacy</option>
                  <option value="research">Research</option>
                  <option value="training">Training</option>
                  <option value="general">General</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label" for="date">Date *</label>
                <input type="date" id="date" class="form-input" required />
              </div>
            </div>

            <!-- Cover Image & Tags -->
            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="coverImage">Cover Image URL *</label>
                <input type="text" id="coverImage" class="form-input" placeholder="/blog/my-cover.jpg" required />
              </div>
              <div class="form-group">
                <label class="form-label" for="tags">Tags (comma separated)</label>
                <input type="text" id="tags" class="form-input" placeholder="Policy, Digital Rights, Sri Lanka" />
              </div>
            </div>

            <!-- Draft toggle -->
            <div class="form-group">
              <label class="form-check">
                <input type="checkbox" id="isDraft" />
                <span class="form-check__label">Save as Draft</span>
              </label>
            </div>

            <!-- Content Editor -->
            <div class="form-group">
              <label class="form-label">Article Content (Markdown) *</label>
              <div class="editor-toolbar">
                <button type="button" class="editor-btn" onclick="insertMarkdown('**', '**')" title="Bold">B</button>
                <button type="button" class="editor-btn" onclick="insertMarkdown('*', '*')" title="Italic"><em>I</em></button>
                <button type="button" class="editor-btn" onclick="insertMarkdown('## ', '')" title="Heading">H2</button>
                <button type="button" class="editor-btn" onclick="insertMarkdown('### ', '')" title="Heading 3">H3</button>
                <button type="button" class="editor-btn" onclick="insertMarkdown('[', '](url)')" title="Link">🔗</button>
                <button type="button" class="editor-btn" onclick="insertMarkdown('![alt](', ')')" title="Image">🖼️</button>
                <button type="button" class="editor-btn" onclick="insertMarkdown('> ', '')" title="Quote">❝</button>
                <button type="button" class="editor-btn" onclick="insertMarkdown('- ', '')" title="List">•</button>
                <button type="button" class="editor-btn" onclick="insertMarkdown('1. ', '')" title="Ordered List">1.</button>
                <button type="button" class="editor-btn" onclick="insertMarkdown('\n---\n', '')" title="Divider">—</button>
              </div>
              <textarea id="content" class="form-input form-textarea editor-area" rows="16" placeholder="Write your article content in Markdown...

# Heading 1
## Heading 2

This is paragraph text with **bold** and *italic*.

- List item one
- List item two

> A blockquote

[Link text](https://example.com)" required></textarea>
            </div>

            <!-- Actions -->
            <div class="form-actions">
              <button type="button" class="btn btn--outline" onclick="previewArticle()">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: -2px; margin-right: 4px;"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                Preview
              </button>
              <button type="button" class="btn btn--primary btn--lg" onclick="generateFile()">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: -2px; margin-right: 4px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Generate &amp; Download
              </button>
            </div>
          </form>
        </div>

        <!-- Preview Modal -->
        <div class="preview-overlay" id="previewOverlay" style="display: none;">
          <div class="preview-modal">
            <div class="preview-modal__header">
              <h3>Article Preview</h3>
              <button class="create-panel__close" onclick="hidePreview()">×</button>
            </div>
            <div class="preview-modal__body" id="previewBody"></div>
          </div>
        </div>

        <!-- Section Tabs -->
        <div class="section-tabs">
          <button class="section-tab section-tab--active" data-tab="articles" onclick="switchSection('articles', this)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: -2px;"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
            Articles ({allArticles.length})
          </button>
          <button class="section-tab" data-tab="blog" onclick="switchSection('blog', this)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: -2px;"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            Blog Posts ({allBlog.length})
          </button>
        </div>

        <!-- Articles Table -->
        <div class="content-section" data-section="articles">
          {allArticles.length > 0 ? (
            <div class="posts-table">
              <div class="posts-table__header">
                <div>Title</div>
                <div>Author</div>
                <div>Category</div>
                <div>Date</div>
                <div>Status</div>
                <div>Actions</div>
              </div>
              {allArticles.map((post) => (
                <div class="posts-table__row">
                  <div class="posts-table__title">
                    <a href={`/articles/${post.slug}`} target="_blank">{post.data.title}</a>
                    {post.data.draft && <span class="badge-draft">DRAFT</span>}
                  </div>
                  <div class="posts-table__author-cell">
                    {post.data.authorImage && (
                      <img src={post.data.authorImage} alt={post.data.author} class="posts-table__author-img" />
                    )}
                    <div>
                      <div class="posts-table__author-name">{post.data.author}</div>
                      {post.data.authorRole && <div class="posts-table__author-role">{post.data.authorRole}</div>}
                    </div>
                  </div>
                  <div><span class={`category-badge category-badge--${post.data.category}`}>{post.data.category}</span></div>
                  <div class="posts-table__date">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</div>
                  <div>
                    {post.data.draft ? (
                      <span class="status-badge status-badge--draft">Draft</span>
                    ) : (
                      <span class="status-badge status-badge--published">Published</span>
                    )}
                  </div>
                  <div class="posts-table__actions">
                    <a href={`/articles/${post.slug}`} target="_blank" class="action-btn action-btn--view" title="View">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    </a>
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <div class="empty-state">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: #94a3b8;"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
              <h3>No articles yet</h3>
              <p>Create your first article by clicking "Create New" above.</p>
            </div>
          )}
        </div>

        <!-- Blog Table -->
        <div class="content-section" data-section="blog" style="display: none;">
          {allBlog.length > 0 ? (
            <div class="posts-table">
              <div class="posts-table__header">
                <div>Title</div>
                <div>Author</div>
                <div>Category</div>
                <div>Date</div>
                <div>Status</div>
                <div>Actions</div>
              </div>
              {allBlog.map((post) => (
                <div class="posts-table__row">
                  <div class="posts-table__title">
                    <a href={`/blog/${post.slug}`} target="_blank">{post.data.title}</a>
                    {post.data.draft && <span class="badge-draft">DRAFT</span>}
                  </div>
                  <div class="posts-table__author-cell">
                    {post.data.authorImage && (
                      <img src={post.data.authorImage} alt={post.data.author} class="posts-table__author-img" />
                    )}
                    <div>
                      <div class="posts-table__author-name">{post.data.author}</div>
                      {post.data.authorRole && <div class="posts-table__author-role">{post.data.authorRole}</div>}
                    </div>
                  </div>
                  <div><span class={`category-badge category-badge--${post.data.category}`}>{post.data.category}</span></div>
                  <div class="posts-table__date">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</div>
                  <div>
                    {post.data.draft ? (
                      <span class="status-badge status-badge--draft">Draft</span>
                    ) : (
                      <span class="status-badge status-badge--published">Published</span>
                    )}
                  </div>
                  <div class="posts-table__actions">
                    <a href={`/blog/${post.slug}`} target="_blank" class="action-btn action-btn--view" title="View">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    </a>
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <div class="empty-state">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: #94a3b8;"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
              <h3>No blog posts yet</h3>
              <p>Create your first blog post by clicking "Create New" above.</p>
            </div>
          )}
        </div>

        <!-- Instructions -->
        <div class="instructions-card">
          <div class="instructions-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
          </div>
          <div>
            <h3 class="instructions-card__title">How to publish content</h3>
            <ol class="instructions-card__list">
              <li>Fill in the form above and click <strong>"Generate & Download"</strong></li>
              <li>A <code>.md</code> file will be downloaded to your computer</li>
              <li>Place the file in <code>src/content/articles/</code> (or <code>src/content/blog/</code> for blog posts)</li>
              <li>Add your cover image to the <code>public/</code> directory</li>
              <li>Commit and push to deploy the changes</li>
            </ol>
          </div>
        </div>

      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ── Admin Header ── */
  .admin-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 32px;
    flex-wrap: wrap;
    gap: 16px;
  }
  .admin-header__title {
    font-size: 1.8rem;
    font-weight: 900;
    color: #0f172a;
    margin: 0;
    letter-spacing: -0.02em;
  }
  .admin-header__sub {
    font-size: 0.9rem;
    color: #64748b;
    margin: 6px 0 0;
  }

  /* ── Stats ── */
  .admin-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }
  .stat-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    transition: all 0.3s ease;
  }
  .stat-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
  }
  .stat-card__icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .stat-card--blue .stat-card__icon { background: rgba(2, 132, 199, 0.1); color: #0284c7; }
  .stat-card--emerald .stat-card__icon { background: rgba(5, 150, 105, 0.1); color: #059669; }
  .stat-card--green .stat-card__icon { background: rgba(16, 185, 129, 0.1); color: #10b981; }
  .stat-card--amber .stat-card__icon { background: rgba(245, 158, 11, 0.1); color: #f59e0b; }
  .stat-card__value {
    font-size: 2rem;
    font-weight: 900;
    color: #0f172a;
    line-height: 1;
  }
  .stat-card__label {
    font-size: 0.8rem;
    color: #94a3b8;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ── Create Panel ── */
  .create-panel {
    background: #ffffff;
    border: 1px solid #e2e8f0;
